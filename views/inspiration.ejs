<!doctype html>
<html lang="en">
  <head>
    <%- include('partials/head', { pageTitle: 'Inspiration' }) %>
  </head>
  <body>
    <div class="page">
      <%- include('partials/sidebar', { currentPage: 'inspiration' }) %>

      <main class="main">
        <div class="container">
          <section class="card">
            <h2>Inspiration</h2>
            <p>A moodboard page for references. I'll replace these with my own art later.</p>
          </section>

          <section class="card">
            <h3>Sources (Pinterest)</h3>
            <ul>
              <li><a href="https://pin.it/7q3foLWjL">Inspiration link 1</a></li>
              <li><a href="https://pin.it/1btLfb40m">Inspiration link 2</a></li>
              <li><a href="https://pin.it/6tQvqCyOz">Inspiration link 3</a></li>
            </ul>
          </section>

          <section class="grid">
            <figure class="card">
              <p><strong>Inspiration #1</strong></p>
              <img
                class="art"
                src="https://i.pinimg.com/736x/e0/73/50/e07350a05d4f4172870d23ba7aeb9149.jpg"
                alt="Inspiration image 1"
              />
            </figure>

            <figure class="card">
              <p><strong>Inspiration #2</strong></p>
              <img
                class="art"
                src="https://i.pinimg.com/1200x/09/95/8b/09958b4711bf672d433e4a04834b7c8a.jpg"
                alt="Inspiration image 2"
              />
            </figure>

            <figure class="card">
              <p><strong>Inspiration #3</strong></p>
              <img
                class="art"
                src="https://i.pinimg.com/1200x/ea/31/75/ea317513d17c317f1f510444eff61380.jpg"
                alt="Inspiration image 3"
              />
            </figure>
          </section>
        </div>
      </main>
    </div>
